#!/bin/bash
# SPDX-License-Identifier: MIT or GPL-2.0-only

# Test UBLK_F_SHMEM_ZC with hugetlbfs for loop target

. common/fio_common
. common/loop_common

HTLB_SH=${TEST_DIR}/../utils/htlb.sh
# fio_common's __run_fio_libaio uses iodepth=128 and the perf sweep goes up
# to 512k bs, so size the hugetlb buffer for 128 * 512k = 64M plus headroom.
HTLB_SIZE_MB=128
HTLB_PARENT=/tmp
HTLB_BUF=${HTLB_PARENT}/huge_${HTLB_SIZE_MB}/ublk_shmem_buf

echo "run loop shmem_zc (hugetlb) test"

if [ ! -x "$HTLB_SH" ]; then
	echo "SKIP: $HTLB_SH not found"
	exit 0
fi

if ! "$HTLB_SH" alloc $HTLB_SIZE_MB $HTLB_PARENT >/dev/null; then
	echo "SKIP: hugetlb alloc failed"
	exit 0
fi

file=`_create_loop_image "data" $LO_IMG_SZ`
export T_TYPE_PARAMS="-t loop -q 1 -f $file --shmem_zc --htlb ${HTLB_BUF}"
export EXTRA_FIO_OPTS="--mem=mmaphuge:${HTLB_BUF}"

__run_dev_perf 1

_remove_loop_image $file
"$HTLB_SH" free $HTLB_SIZE_MB $HTLB_PARENT >/dev/null
